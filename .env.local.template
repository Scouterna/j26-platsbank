
# Database URL for PostgreSQL
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/platsbank"

# OIDC discovery document used to verify JWTs (provides the issuer and JWKS URL)
KEYCLOAK_DISCOVERY_URL="https://app.dev.j26.se/auth/.well-known/openid-configuration"

# Tolgee translations (exposed to the client — must keep the J26_PUBLIC_ prefix)
J26_PUBLIC_TOLGEE_BACKEND_FETCH_PREFIX=https://j26-translations.jamboree.se/<export-id>
# The following three variables are used only in the development environment
J26_PUBLIC_TOLGEE_API_URL=https://j26-tolgee.nihlen.dev
J26_PUBLIC_TOLGEE_API_KEY=<replace-with-your-personal-access-token>
J26_PUBLIC_TOLGEE_PROJECT_ID=2
