generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Request {
  id           String          @id @default(uuid())
  // Swedish is the source language; the *En fields hold the mandatory English
  // translation. Both languages are required to publish (enforced in the
  // create/update server functions). Display picks a language at read time.
  title         String
  titleEn       String
  description   String
  descriptionEn String
  startTime    DateTime
  endTime      DateTime
  peopleNeeded Int
  location     String
  locationEn   String
  contactName  String?
  contactPhone String?
  createdBy    String
  creatorName  String
  types        String[]        @default(["leader"])
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  signups      RequestSignup[]
  blocks       RequestBlock[]
}

model RequestBlock {
  id        String   @id @default(uuid())
  requestId String
  userId    String
  userName  String
  reason    String
  createdAt DateTime @default(now())
  request   Request  @relation(fields: [requestId], references: [id], onDelete: Cascade)

  @@unique([requestId, userId])
}

model RequestSignup {
  id         String   @id @default(uuid())
  requestId  String
  userId     String
  userName   String
  scoutGroup String?
  phone      String?
  comment    String?
  claimToken String?  @unique
  createdAt  DateTime @default(now())
  request    Request  @relation(fields: [requestId], references: [id], onDelete: Cascade)

  @@unique([requestId, userId])
}
