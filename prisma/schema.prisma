generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Request {
  id           String   @id @default(uuid())
  title        String
  description  String
  startTime    DateTime
  endTime      DateTime
  peopleNeeded Int
  location     String?
  createdBy    String
  creatorName  String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
