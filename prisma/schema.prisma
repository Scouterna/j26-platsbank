generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Request {
  id           String          @id @default(uuid())
  title        String
  description  String
  startTime    DateTime
  endTime      DateTime
  peopleNeeded Int
  location     String?
  contactName  String?
  contactPhone String?
  createdBy    String
  creatorName  String
  type         String          @default("leader")
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  signups      RequestSignup[]
  blocks       RequestBlock[]
}

model RequestBlock {
  id        String   @id @default(uuid())
  requestId String
  userId    String
  userName  String
  reason    String
  createdAt DateTime @default(now())
  request   Request  @relation(fields: [requestId], references: [id], onDelete: Cascade)

  @@unique([requestId, userId])
}

model RequestSignup {
  id         String   @id @default(uuid())
  requestId  String
  userId     String
  userName   String
  scoutGroup String?
  comment    String?
  claimToken String?  @unique
  createdAt  DateTime @default(now())
  request    Request  @relation(fields: [requestId], references: [id], onDelete: Cascade)

  @@unique([requestId, userId])
}
